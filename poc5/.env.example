# ─────────────────────────────────────────────────────────────
# CQRS Reporting PoC — Environment Variables
# Kopieer dit naar .env en pas aan naar je omgeving
# ─────────────────────────────────────────────────────────────

# ─── RabbitMQ ───
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── OrderDB (Write-Side) ───
ORDERDB_HOST=orderdb
ORDERDB_PORT=5432
ORDERDB_NAME=orderdb
ORDERDB_USER=orderuser
ORDERDB_PASSWORD=orderpass

# ─── ReportingDB (Read-Side) ───
REPORTINGDB_HOST=reportingdb
REPORTINGDB_PORT=5432
REPORTINGDB_NAME=reportingdb
REPORTINGDB_USER=reportinguser
REPORTINGDB_PASSWORD=reportingpass

# ─── Flask ───
FLASK_ENV=production
FLASK_DEBUG=0

# ─── Logging ───
LOG_LEVEL=INFO
